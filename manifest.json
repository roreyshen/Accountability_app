{
  "manifest_version": 3,
  "name": "Stay Focused",
  "version": "1.2",
  "description": "Blocks distracting websites.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stay Focused"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["block-content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
