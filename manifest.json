{
  "manifest_version": 3,
  "name": "Stay Focused",
  "version": "1.4",
  "description": "Blocks distracting websites and tracks your focus activity.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stay Focused",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["block-content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js", "stats.html", "stats.js", "privacy.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
