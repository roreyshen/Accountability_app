{
  "manifest_version": 3,
  "name": "Stay Focused",
  "version": "1.1",
  "description": "Blocks distracting websites.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["block-content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
